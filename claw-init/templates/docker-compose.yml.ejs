###############################################################################
# <%= config.name || 'claw' %> — Multi-agent collaborative sandbox
#
# Generated by claw init. Edit claw.yaml and re-run to regenerate.
#
# Networks:
#   jailed   - internal only, no internet. agents + synapse live here.
#   gateway  - has internet. only mitmproxy lives here.
###############################################################################

services:
  # ── cert-init (one-shot: generate mitmproxy CA certs) ─────────────────────
  cert-init:
    image: mitmproxy/mitmproxy:latest
    container_name: <%= config.name || 'claw' %>-cert-init
    entrypoint: >
      sh -c '
        if [ ! -f /certs/mitmproxy-ca-cert.pem ]; then
          echo ">> Generating mitmproxy CA certificates..."
          mitmdump --set confdir=/certs -k &
          sleep 2 && kill $$! 2>/dev/null
          echo ">> CA certs written to /certs/"
          ls -la /certs/
        else
          echo ">> CA certs already exist, skipping."
        fi
      '
    volumes:
      - ./mitmproxy/certs:/certs
    networks: []

  # ── synapse (Matrix homeserver) ───────────────────────────────────────────
  synapse:
    image: matrixdotorg/synapse:latest
    container_name: <%= config.name || 'claw' %>-synapse
    volumes:
      - ./synapse-data:/data
    ports:
      - "<%= ports.synapse %>:8008"
    networks:
      jailed:
      gateway:
    healthcheck:
      test: ["CMD", "curl", "-fSs", "http://localhost:8008/health"]
      interval: 5s
      timeout: 3s
      retries: 10

  # ── mitmproxy (egress control + traffic inspector) ────────────────────────
  mitmproxy:
    image: mitmproxy/mitmproxy:latest
    container_name: <%= config.name || 'claw' %>-mitmproxy
    depends_on:
      cert-init:
        condition: service_completed_successfully
    command: >
      mitmweb
        --web-host 0.0.0.0
        --listen-port 8080
        --set confdir=/home/mitmproxy/.mitmproxy
        --scripts /scripts/allowlist.py
        --scripts /scripts/logger.py
        --set hardump=/logs/traffic.har
    volumes:
      - ./mitmproxy/scripts:/scripts:ro
      - ./mitmproxy/certs:/home/mitmproxy/.mitmproxy
      - ./logs:/logs
    ports:
      - "<%= ports.mitmproxy_ui %>:8081"
    networks:
      jailed:
      gateway:
    healthcheck:
      test: ["CMD", "python3", "-c", "import socket; s=socket.create_connection(('localhost',8081),2); s.close()"]
      interval: 5s
      timeout: 3s
      retries: 10

  # ── element (Matrix web client) ───────────────────────────────────────────
  element:
    image: vectorim/element-web:latest
    container_name: <%= config.name || 'claw' %>-element
    ports:
      - "<%= ports.element %>:80"
    volumes:
      - ./element-config.json:/app/config.json:ro
    restart: unless-stopped

  # ── claw-provision (one-shot: register accounts + create room) ────────────
  claw-provision:
    build: ../claw-init
    container_name: <%= config.name || 'claw' %>-provision
    command: ["node", "init.mjs", "provision"]
    depends_on:
      synapse:
        condition: service_healthy
    environment:
      SYNAPSE_URL: "http://synapse:8008"
      SHARED_SECRET: "<%= secrets.registration_shared_secret %>"
      PROVISION_CONFIG: '<%-  provisionConfig %>'
    volumes:
      - ./provision-data:/data
    networks:
      jailed:

<% for (const agent of agents) { %>
  # ── agent: <%= agent.display_name %> ──────────────────────────────────────
  agent-<%= agent.name %>:
<% if (agent.image) { %>
    image: <%= agent.image %>
<% } else { %>
    build: ../claw-agent
<% } %>
    container_name: <%= config.name || 'claw' %>-<%= agent.name %>
    depends_on:
      mitmproxy:
        condition: service_healthy
      synapse:
        condition: service_healthy
      claw-provision:
        condition: service_completed_successfully
    environment:
      # Force traffic through mitmproxy
      HTTP_PROXY:  "http://mitmproxy:8080"
      HTTPS_PROXY: "http://mitmproxy:8080"
      NO_PROXY:    "localhost,127.0.0.1,synapse"

      # Trust mitmproxy CA
      NODE_EXTRA_CA_CERTS: "/mitmproxy-ca/mitmproxy-ca-cert.pem"
      SSL_CERT_FILE:       "/mitmproxy-ca/mitmproxy-ca-cert.pem"

      # Matrix connection
      MATRIX_HOMESERVER: "http://synapse:8008"
      MATRIX_USER: "<%= agent.username %>"
      MATRIX_PASSWORD: "<%= agent.password %>"
      BOT_DISPLAY_NAME: "<%= agent.display_name %>"

      # Agent config
      AGENT_MODEL: "<%= agent.model %>"
      AGENT_MAX_TURNS: "<%= agent.max_turns %>"
      RESPOND_TO: "<%= agent.respond_to %>"
      BOT_USERS: "<%= allBotUsernames.join(',') %>"
      HEARTBEAT_ROOM: "#<%= roomAlias %>:<%= serverName %>"
      AGENT_HEARTBEAT_INTERVAL: "<%= agent.heartbeat_interval %>"
      AGENT_REFLECTION_INTERVAL: "<%= agent.reflection_interval %>"

      TZ: "${TZ:-America/Los_Angeles}"
<% for (const [k, v] of Object.entries(agent.env)) { %>
      <%= k %>: "<%= v %>"
<% } %>
    env_file:
      - ../<%= envFile %>
    volumes:
      - ./agent-config/<%= agent.name %>:/config:ro
      - ./agent-data/<%= agent.name %>:/data
      - ./mitmproxy/certs:/mitmproxy-ca:ro
<% for (const ws of agent.workspace) { %>
      - <%= ws %>
<% } %>
    dns:
      - 8.8.8.8
      - 1.1.1.1
    networks:
      jailed:
      gateway:
    restart: unless-stopped
<% } %>

networks:
  jailed:
    internal: true
  gateway:
