"""
Domain allowlist addon for mitmproxy.
Generated by claw init — egress mode: <%= egressMode %>
"""

from mitmproxy import http, ctx

ALLOWED_DOMAINS: set[str] = {
    # LLM API Providers
    ".anthropic.com",
    ".openai.com",
    "generativelanguage.googleapis.com",
    "api.groq.com",
    ".together.xyz",
    ".openrouter.ai",
    "api.mistral.ai",

    # Local / Self-Hosted
    "host.docker.internal",
    "localhost",
    "127.0.0.1",

    # Web Search
    "api.search.brave.com",
    "api.tavily.com",

    # Code & Package Registries
    ".github.com",
    ".githubusercontent.com",
    "registry.npmjs.org",
    ".npmjs.com",
    ".pypi.org",
    "files.pythonhosted.org",

    # Documentation
    ".stackoverflow.com",
    ".readthedocs.io",
    ".developer.mozilla.org",
    ".wikipedia.org",
}

<% if (egressMode === 'log-only') { %>
ALLOW_ALL_TRAFFIC = True
<% } else { %>
ALLOW_ALL_TRAFFIC = False
<% } %>

PASSTHROUGH_DOMAINS: set[str] = set()


def _is_allowed(host: str) -> bool:
    host = host.lower().strip()
    for pattern in ALLOWED_DOMAINS:
        if pattern.startswith("."):
            if host.endswith(pattern) or host == pattern[1:]:
                return True
        else:
            if host == pattern:
                return True
    return False


class AllowlistAddon:
    def request(self, flow: http.HTTPFlow) -> None:
        host = flow.request.pretty_host

        if ALLOW_ALL_TRAFFIC:
            ctx.log.info(f"[PASS] {flow.request.method} {flow.request.pretty_url}")
            return

        if not _is_allowed(host):
            ctx.log.warn(f"[BLOCKED] {flow.request.method} {flow.request.pretty_url}")
            flow.response = http.Response.make(
                403,
                f"BLOCKED by allowlist: {host} is not in the allowed domains.\n",
                {"Content-Type": "text/plain"},
            )
        else:
            ctx.log.info(f"[ALLOWED] {flow.request.method} {flow.request.pretty_url}")

    def tls_clienthello(self, data):
        host = data.context.server.address[0] if data.context.server else ""
        if host.lower().strip() in PASSTHROUGH_DOMAINS:
            data.ignore_connection = True


addons = [AllowlistAddon()]
