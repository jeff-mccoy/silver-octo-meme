# Synapse configuration — generated by claw init
# Private homeserver, no federation, SQLite backend.

server_name: "<%= serverName %>"
pid_file: /data/homeserver.pid

listeners:
  - port: 8008
    resources:
    - compress: false
      names:
      - client
    tls: false
    type: http
    x_forwarded: true

database:
  name: sqlite3
  args:
    database: /data/homeserver.db

log_config: "/data/<%= serverName %>.log.config"
media_store_path: /data/media_store

registration_shared_secret: "<%= secrets.registration_shared_secret %>"

# No open registration — accounts created by claw-provision
enable_registration: false

# No federation — private homeserver
trusted_key_servers: []
federation_domain_whitelist: []

report_stats: false
macaroon_secret_key: "<%= secrets.macaroon_secret_key %>"
form_secret: "<%= secrets.form_secret %>"
signing_key_path: "/data/<%= serverName %>.signing.key"

# Disable rate limiting — private server, only bots
rc_login:
  address:
    per_second: 100
    burst_count: 100
  account:
    per_second: 100
    burst_count: 100
rc_message:
  per_second: 100
  burst_count: 100
rc_joins:
  local:
    per_second: 100
    burst_count: 100
